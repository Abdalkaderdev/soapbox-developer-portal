# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# SoapBox API Configuration
# The base URL for the SoapBox backend API (includes /api/v1 prefix)
# This URL is used by all developer portal API routes to proxy requests
SOAPBOX_API_URL=https://api.soapboxsuperapp.com/api/v1

# For local development against local API server:
# SOAPBOX_API_URL=http://localhost:5000/api/v1

# For staging environment:
# SOAPBOX_API_URL=https://staging-api.soapboxsuperapp.com/api/v1
